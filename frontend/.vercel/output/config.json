{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/mis-torneos/?$",
			"dest": "_render"
		},
		{
			"src": "^/perfil/?$",
			"dest": "_render"
		},
		{
			"src": "^/ranking/?$",
			"dest": "_render"
		},
		{
			"src": "^/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/torneos/nuevo/?$",
			"dest": "_render"
		},
		{
			"src": "^/torneos/([^/]+?)/resumen/?$",
			"dest": "_render"
		},
		{
			"src": "^/torneos/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/torneos/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}