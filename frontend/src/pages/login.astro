---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Login - Gestor de Torneos" description="Inicia sesión">
  <div class="container auth-container">
    <div class="card auth-card">
      <h1>Iniciar sesión</h1>
      <p class="auth-subtitle">Accede para gestionar torneos e inscripciones.</p>

      <div id="login-message" class="alert" style="display:none;"></div>

      <form id="login-form" class="auth-form">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required />

        <label for="password">Password</label>
        <input id="password" name="password" type="password" required />

        <button type="submit" class="button button-primary">Entrar</button>
      </form>
      <p class="auth-extra">
        ¿No tienes cuenta? <a href="/register">Regístrate aquí</a>
      </p>
    </div>
  </div>
</MainLayout>

<script>
  import { login } from '../lib/api';

  const TOKEN_KEY = 'authToken';
  const USER_KEY = 'authUser';

  function showMessage(text, level = 'error') {
    const messageBox = document.getElementById('login-message');
    if (!messageBox) return;
    messageBox.className = `alert alert-${level}`;
    messageBox.textContent = text;
    messageBox.style.display = 'block';
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (localStorage.getItem(TOKEN_KEY)) {
      window.location.href = '/torneos';
      return;
    }

    const form = document.getElementById('login-form');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const email = String(formData.get('email') || '');
      const password = String(formData.get('password') || '');

      try {
        const response = await login(email, password);
        localStorage.setItem(TOKEN_KEY, response.token);
        localStorage.setItem(
          USER_KEY,
          JSON.stringify({
            id: response.id,
            nombre: response.nombre,
            email: response.email,
            rol: response.rol,
          })
        );
        window.location.href = '/torneos';
      } catch (error) {
        showMessage(error instanceof Error ? error.message : 'Error al iniciar sesión', 'error');
      }
    });
  });
</script>

<style>
  .auth-container {
    max-width: 480px;
    margin: 0 auto;
    padding-top: var(--spacing-xl);
  }

  .auth-card h1 {
    margin-bottom: var(--spacing-sm);
  }

  .auth-subtitle {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .auth-form input {
    padding: var(--spacing-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font: inherit;
    margin-bottom: var(--spacing-sm);
  }

  .auth-extra {
    margin-top: var(--spacing-md);
    color: var(--color-text-secondary);
  }
</style>
